NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Серверные ключи (только для API routes, не NEXT_PUBLIC)
GEMINI_API_KEY=...            # для эмбеддингов (Gemini text-embedding-004) — https://aistudio.google.com/app/apikey
GROQ_API_KEY=gsk_...          # для генерации ответов (Llama 3.3 70B)
TELEGRAM_BOT_TOKEN=...        # тот же, что в backend/.env — для рассылки «Отправить всем в ТГ»
